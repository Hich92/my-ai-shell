generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["sys_org", "core"]
}

/// Model for Entities (Contacts/Companies)
model Entity {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  isCompany  Boolean  @map("is_company")
  email      String?
  phone      String?
  parentId   String?  @map("parent_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  isActive   Boolean  @default(true) @map("is_active")

  // Relations
  notes      Note[]
  
  @@map("m_entities")
  @@schema("sys_org")
}

/// Model for System Notes (The Chatter)
model Note {
  id        String   @id @default(uuid()) @db.Uuid
  targetId  String   @map("target_id") @db.Uuid
  content   String
  author    String   @default("System")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  entity    Entity   @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@map("t_notes")
  @@schema("core")
}

/// Model for System Audit Trail
model Audit {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("t_audit")
  @@schema("core")
}
